{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": ["id", "claim", "verdict", "epistemic", "context", "meta"],
    "additionalProperties": false,

    "properties": {
        "id": {"type": "string"},
        "claim": {"type": "string"},

        "verdict": {
            "type": "object",
            "required": ["label", "justification", "annotator_confidence"],
            "properties": {
                "label": {
                    "type": ["string", "null"],
                    "enum": [
                        "supported",
                        "refuted",
                        "not_enough_evidence",
                        "conflicting_evidence",
                        "cherrypicking",
                        null
                    ]
                },
                "justification": {"type": ["string", "null"]},
                "annotator_confidence": {"type": ["number", "null"]}
            }
        },

        "epistemic": {
            "type": "object",
            "required": ["proof_types", "primary_proof_type", "proof_type_rationale", "proof_confidence"],
            "properties": {
                "proof_types": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string",
                        "enum": [
                        "perception",
                        "inference",
                        "testimony",
                        "comparison_analogy",
                        "postulation_derivation",
                        "non_apprehension"
                        ]
                    }     
                },
                "primary_proof_type": {
                    "type": "string",
                    "enum": [
                        "perception",
                        "inference",
                        "testimony",
                        "comparison_analogy",
                        "postulation_derivation",
                        "non_apprehension"
                    ]
                },
                "proof_type_rationale": {"type": ["string", "null"]},
                "proof_confidence": {"type": ["number", "null"]}
            }
        },

        "claim_meta": {"type": ["object", "null"]},
        "claim_triples": {"type": ["array", "null"]},
        "reasoning": {"type": ["object", "null"]},
        "qa": {"type": ["array", "null"]},
        "evidence_items": {"type": ["array", "null"]},

        "context": {
            "type": "object",
            "required": ["context_id", "context_type", "generator"],
            "properties": {
                "context_id": {"type": ["string", "null"]},
                "context_type": {"type": "string"},
                "generator": {"type": "string"},
                "split": {"type": ["string", "null"]}
            }
        },

        "meta": {
            "type": "object",
            "required": ["created_utc", "notes"],
            "properties": {
                "created_utc": {"type": "string"},
                "notes": {"type": ["string", "null"]}
            }
        }
    }
}